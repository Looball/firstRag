DATABASE_URL=postgresql://username:password@localhost:5432/first_rag
# Docker Compose 使用的 PostgreSQL 容器配置；不影响 conda 本地启动。
POSTGRES_DB=first_rag
POSTGRES_USER=firstrag
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
# 公开演示环境建议只绑定到本机端口，由反向代理暴露 80/443。
# FRONTEND_PORT=127.0.0.1:3000
# BACKEND_PORT=127.0.0.1:8000
# POSTGRES_PORT=127.0.0.1:5432
# 前端高级/开发入口默认关闭；设为 true 时，新浏览器会默认显示诊断、质量看板和检索参数。
NEXT_PUBLIC_FIRSTRAG_ADVANCED_MODE_DEFAULT=false
# 可选：仅在使用外部数据库或自定义连接串时覆盖 compose 内数据库连接。
# 不填时 compose 会根据 POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD 构造连接串。
# COMPOSE_DATABASE_URL=postgresql://firstrag:replace-with-a-strong-postgres-password@postgres:5432/first_rag
JWT_SECRET_KEY=replace-with-a-random-secret
# 本地开发默认允许注册；公开 demo 建议设为 false，只开放预置账号。
ALLOW_PUBLIC_REGISTRATION=true
# 聊天模型 provider/model/API Key 和向量模型 provider/model/API Key 登录后在设置页配置。
# 下面仅是聊天模型生成参数的默认值。
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8000
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
# 使用下方命令生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
USER_SETTINGS_ENCRYPTION_KEY=replace-with-a-fernet-key
# 默认关闭，防止用户借模型配置访问服务器内网；仅在配置出口策略后开启。
ALLOW_USER_CUSTOM_LLM_BASE_URL=false
# Rerank provider 可选 local / qwen / dashscope。默认 local 使用本地 CrossEncoder。
# 切到阿里云 qwen3-rerank 时，需要配置 RERANK_BASE_URL 为工作空间 OpenAI-compatible 地址。
RERANK_PROVIDER=local
RERANK_MODEL=
RERANK_BASE_URL=
RERANK_API_KEY=
DASHSCOPE_API_KEY=
QWEN_API_KEY=
RERANK_INSTRUCT=
# 公开演示环境建议调小上传上限，并与反向代理 body size 保持一致。
MAX_UPLOAD_FILE_SIZE_BYTES=20971520
# 用户级上传配额；设为 0 表示关闭对应限制。
USER_UPLOAD_MAX_FILES=200
USER_UPLOAD_MAX_BYTES=2147483648
# 单次知识库批量向量化最多提交的文件数；设为 0 表示关闭限制。
VECTOR_INDEX_MAX_BATCH_FILES=100
# 进程内限流；公网多实例部署仍建议叠加反向代理、WAF 或 API 网关限流。
LOGIN_FAILURE_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_FAILURE_RATE_LIMIT_WINDOW_SECONDS=300
API_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_RATE_LIMIT_MAX_REQUESTS=60
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
VECTOR_INDEX_RATE_LIMIT_MAX_REQUESTS=30
MODEL_TEST_RATE_LIMIT_MAX_REQUESTS=20
# 生产环境建议把以下目录放到独立数据盘，并纳入备份策略。
# UPLOADS_DIR=/srv/firstrag/uploads
# VECTOR_DB_DIR=/srv/firstrag/vector_db
# MODELS_DIR=/srv/firstrag/models
# Docker stdout/stderr 日志轮转，避免日志无限增长。
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
VECTOR_STORE_PATH=./vector_db/chroma
CHROMA_COLLECTION_NAME=langchain
RERANKER_MODEL_PATH=models/rerankers/bge-reranker-base
