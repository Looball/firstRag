DATABASE_URL=postgresql://username:password@localhost:5432/first_rag
# Docker Compose 使用的 PostgreSQL 容器配置；不影响 conda 本地启动。
POSTGRES_DB=first_rag
POSTGRES_USER=firstrag
POSTGRES_PASSWORD=replace-with-a-local-postgres-password
# 公开演示环境建议只绑定到本机端口，由反向代理暴露 80/443。
# FRONTEND_PORT=127.0.0.1:3000
# BACKEND_PORT=127.0.0.1:8000
# POSTGRES_PORT=127.0.0.1:5432
# 可选：覆盖 compose 内 backend/worker 的数据库连接，不填则连接 postgres 服务。
# COMPOSE_DATABASE_URL=postgresql://firstrag:replace-with-a-local-postgres-password@postgres:5432/first_rag
JWT_SECRET_KEY=replace-with-a-random-secret
# 默认 DeepSeek。未配置 LLM_API_KEY 时，会兼容读取 DEEPSEEK_API_KEY。
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=replace-with-your-llm-api-key
# 可选：不填则使用对应厂商的预设 OpenAI 兼容地址。
# LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8000
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
# DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
# 使用下方命令生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
USER_SETTINGS_ENCRYPTION_KEY=replace-with-a-fernet-key
# 默认关闭，防止用户借模型配置访问服务器内网；仅在配置出口策略后开启。
ALLOW_USER_CUSTOM_LLM_BASE_URL=false
ZAI_EMD_API=replace-with-your-zhipu-api-key
# 公开演示环境建议调小上传上限，并与反向代理 body size 保持一致。
MAX_UPLOAD_FILE_SIZE_BYTES=20971520
VECTOR_STORE_PATH=./vector_db/chroma
CHROMA_COLLECTION_NAME=langchain
RERANKER_MODEL_PATH=models/rerankers/bge-reranker-base
